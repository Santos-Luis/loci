{
  "name": "loci",
  "version": "0.1.0",
  "description": "A local-first AI agent that remembers what you care about and thinks while you don't",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "npm run build && electron-builder",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3",
    "typecheck": "tsc --noEmit && tsc -p tests/tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "better-sqlite3": "12.10.0",
    "knex": "3.2.10",
    "marked": "14.1.4",
    "node-cron": "3.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@electron-toolkit/utils": "4.0.0",
    "@electron/rebuild": "3.7.2",
    "@eslint/js": "9.39.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "24.13.1",
    "@types/node-cron": "3.0.11",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "35.7.5",
    "electron-builder": "26.15.0",
    "electron-vite": "3.1.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "16.4.0",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "3.2.6"
  },
  "build": {
    "appId": "app.loci",
    "productName": "Loci",
    "npmRebuild": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "files": [
      "out/**",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
